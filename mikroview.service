[Unit]
Description=MikroView Dashboard
After=network.target

[Service]
Type=simple
User=ouc
WorkingDirectory=/home/ouc/mikroview
Environment="PATH=/home/ouc/.hermes/hermes-agent/venv/bin:/usr/bin"
ExecStart=/home/ouc/.hermes/hermes-agent/venv/bin/gunicorn -w 2 -b 127.0.0.1:5050 app:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
